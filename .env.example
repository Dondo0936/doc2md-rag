# Optional: enables Claude Vision for AI-powered image descriptions in PDFs
# Get your key at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional: API-based embedding models (only set the ones you plan to use)

# OpenAI — for text-embedding-3-small / text-embedding-3-large
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...

# Voyage AI (Anthropic-recommended) — for voyage-3.5-lite
# Get your key at https://dash.voyageai.com
VOYAGE_API_KEY=pa-...

# Google Gemini — for gemini-embedding-001 / text-embedding-004
# Get your key at https://aistudio.google.com/apikey
GEMINI_API_KEY=AI...
